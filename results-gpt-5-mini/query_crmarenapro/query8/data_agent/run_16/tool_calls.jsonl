led > 0 cases\nagents_with_cases = [agent for agent, cases in handled_cases.items() if len(cases) > 0]\n\nif not agents_with_cases:\n    result = None\nelse:\n    # compute transfer counts for these agents (default 0)\n    min_count = None\n    agents_min = []\n    for agent in agents_with_cases:\n        cnt = transfer_counts.get(agent, 0)\n        if (min_count is None) or (cnt < min_count):\n            min_count = cnt\n            agents_min = [agent]\n        elif cnt == min_count:\n            agents_min.append(agent)\n    # deterministic pick: lexicographically smallest id\n    chosen = sorted(agents_min)[0]\n    result = chosen\n\nprint(\"__RESULT__:\")\nprint(json.dumps(result))", "env": {"var_call_nx7cdbl1ncpumWLGplQLjhek": ["Case", "knowledge__kav", "issue__c", "casehistory__c", "emailmessage", "livechattranscript"], "var_call_RXbuucCeFavYEk46zfMGcOnW": [{"field__c": "Owner Assignment", "cnt": "165"}, {"field__c": "Case Creation", "cnt": "153"}, {"field__c": "Case Closed", "cnt": "75"}], "var_call_tICXPPpjst0AUGl4Dlxb279S": [{"id": "#a04Wt000005376xIAA", "caseid__c": "500Wt00000DDzxRIAT", "oldvalue__c": "None", "newvalue__c": "005Wt000003NIVZIA4", "createddate": "2022-04-16T09:45:00.000+0000"}, {"id": "a04Wt000005381PIAQ", "caseid__c": "500Wt00000DDg1zIAD", "oldvalue__c": "None", "newvalue__c": "005Wt000003NJrRIAW", "createddate": "2022-04-17T14:20:00.000+0000"}, {"id": "#a04Wt00000537oVIAQ", "caseid__c": "500Wt00000DDPZ0IAP", "oldvalue__c": "None", "newvalue__c": "005Wt000003NJD9IAO", "createddate": "2022-04-18T10:30:00.000+0000"}, {"id": "a04Wt00000536m0IAA", "caseid__c": "500Wt00000DDg8RIAT", "oldvalue__c": "None", "newvalue__c": "005Wt000003NEGhIAO", "createddate": "2022-05-10T11:30:00.000+0000"}, {"id": "a04Wt00000534XJIAY", "caseid__c": "500Wt00000DDgLLIA1", "oldvalue__c": "None", "newvalue__c": "005Wt000003NDqFIAW", "createddate": "2022-05-12T14:45:00.000+0000"}, {"id": "a04Wt00000532wtIAA", "caseid__c": "500Wt00000DDZtLIAX", "oldvalue__c": "None",