ddate": "2023-03-16T14:45:00.000+0000"}, {"id": "a04Wt00000537GcIAI", "caseid__c": "500Wt00000DDzPZIA1", "oldvalue__c": "None", "newvalue__c": "005Wt000003NBcAIAW", "createddate": "2023-03-17T11:20:00.000+0000"}, {"id": "a04Wt00000539aCIAQ", "caseid__c": "500Wt00000DDyRvIAL", "oldvalue__c": "None", "newvalue__c": "005Wt000003NISLIA4", "createddate": "2023-03-20T14:15:00.000+0000"}, {"id": "a04Wt00000539zyIAA", "caseid__c": "500Wt00000DE0FDIA1", "oldvalue__c": "None", "newvalue__c": "005Wt000003NFKoIAO", "createddate": "2023-03-22T14:30:00.000+0000"}, {"id": "#a04Wt0000053A6PIAU", "caseid__c": "500Wt00000DE0VJIA1", "oldvalue__c": "None", "newvalue__c": "005Wt000003NJ0DIAW", "createddate": "2023-03-23T09:15:00.000+0000"}, {"id": "#a04Wt00000539jrIAA", "caseid__c": "500Wt00000DDPsPIAX", "oldvalue__c": "None", "newvalue__c": "005Wt000003NJ8HIAW", "createddate": "2023-04-05T17:51:00.000+0000"}]}}, "val_args": {"code": "import json\nfrom collections import defaultdict\n\nrecords = var_call_KuRQKGnBxg2sWMh586KB9exD\n\ndef norm(idval):\n    if idval is None:\n        return None\n    s = str(idval).strip()\n    if s == '' or s.lower() == 'none':\n        return None\n    if s.startswith('#'):\n        s = s[1:]\n    return s\n\ntransfer_counts = defaultdict(int)\nhandled_cases = defaultdict(set)\n\nfor r in records:\n    oldv = norm(r.get('oldvalue__c'))\n    newv = norm(r.get('newvalue__c'))\n    caseid = r.get('caseid__c')\n    if caseid is not None:\n        caseid = str(caseid).strip()\n        if caseid.startswith('#'):\n            caseid = caseid[1:]\n    # count transfers for the agent who transferred away (oldvalue)\n    if oldv is not None:\n        transfer_counts[oldv] += 1\n    # record that agent handled this case if they are the new owner\n    if newv is not None and caseid is not None:\n        handled_cases[newv].add(caseid)\n\n# ensure agents that appear only in transfer_counts but never in handled_cases have handled 0\n# Now filter agents with handled > 0\ncandidates = []\nfor agent, cases in handled_cases.items():\n    if len(cases) > 0:\n        tc = transfer_counts.get(agent, 0)\n        candidates.append((agent, tc))\n\nif not candidates:\n    result = None\nelse:\n    # find min transfer count\n    min_tc = min(tc for _, tc in candidates)\n    # agents with min_tc\n    min_agents = sorted([agent for agent, tc in candidates if tc == min_tc])\n    # choose first (lexicographically smallest) to return single Id\n    result = min_agents[0]\n\nprint(\"__RESULT__:\")\nprint(json.dumps(result))", "env": {"var_call_n2UWolI3IaeC0eZj0wAa85TL": ["Case", "knowledge__kav", "issue__c", "casehistory__c", "emailmessage", "livechattranscript"], "var_call_B7N4Q93UDyFBpeypQ0cHjKdl": [{"field__c": "Owner Assignment", "cnt": "39"}, {"field__c": "Case Creation", "cnt": "38"}, {"field__c": "Case Closed", "cnt": "21"}], "var_call_KuRQKGnBxg2sWMh586KB9exD": [{"id": "#a04Wt000005376xIAA", "caseid__c": "500Wt00000DDzxRIAT", "oldvalue__c": "None", "newvalue__c": "005Wt000003NIVZIA4", "createddate": "2022-04-16T09:45:00.000+0000"}, {"id": "a04Wt000005381PIAQ", "caseid__c": "500Wt00000DDg1zIAD", "oldvalue__c": "None", "newvalue__c": "005Wt000003NJrRIAW", "createddate": "2022-04-17T14:20:00.000+0000"}, {"id": "#a04Wt00000537oVIAQ", "caseid__c": "500Wt00000DDPZ0IAP", "oldvalue__c": "None", "newvalue__c": "005Wt000003NJD9IAO", "createddate": "2022-04-18T10:30:00.000+0000"}, {"id": "a04Wt00000536m0IAA", "caseid__c": "500Wt00000DDg8RIAT", "oldvalue__c": "None", "newvalue__c": "005Wt000003NEGhIAO", "createddate": "2022-05-10T11:30:00.000+0000"}, {"id": "a04Wt00000534XJIAY", "caseid__c": "500Wt00000DDgLLIA1", "oldvalue__c": "None", "newvalue__c": "005Wt000003NDqFIAW", "createddate": "2022-05-12T14:45:00.000+0000"}, {"id": "a04Wt00000532wtIAA", "caseid__c": "500Wt00000DDZtLIAX", "oldvalue__c": "None", "newvalue__c": "005Wt000003NIliIAG", "createddate": "2022-05-15T14:00:00.000+0000"}, {"id": "#a04Wt00000539iDIAQ", "caseid__c": "500Wt00000DDZtLIAX",