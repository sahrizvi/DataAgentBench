 oldvalue__c AS agent_id, COUNT(*) AS transfer_count\n  FROM casehistory__c\n  WHERE field__c='Owner Assignment' AND createddate >= '2022-04-10' AND createddate < '2023-04-10' AND oldvalue__c IS NOT NULL AND oldvalue__c != 'None'\n  GROUP BY oldvalue__c\n) t\nFULL JOIN (\n  SELECT newvalue__c AS agent_id, COUNT(DISTINCT caseid__c) AS handled_cases\n  FROM casehistory__c\n  WHERE field__c='Owner Assignment' AND createddate >= '2022-04-10' AND createddate < '2023-04-10' AND newvalue__c IS NOT NULL AND newvalue__c != 'None'\n  GROUP BY newvalue__c\n) h ON t.agent_id = h.agent_id\nWHERE COALESCE(h.handled_cases,0) > 0\nORDER BY transfer_count ASC NULLS LAST\nLIMIT 10;"}}}
