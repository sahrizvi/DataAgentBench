1:]\n    clean = clean.strip()\n    state = a.get('ShippingState')\n    if state is None:\n        continue\n    state = state.strip()\n    acct_map[clean] = state\n\n# helper to parse timestamps like 2022-08-05T14:39:32.000+0000\ndef parse_ts(s):\n    if s is None:\n        return None\n    s = s.strip()\n    # Replace +0000 style timezone to +00:00\n    if s.endswith('Z'):\n        s = s[:-1] + '+00:00'\n    if '+' in s[-6:] or '-' in s[-6:]:\n        # last 5 or 6 chars are timezone like +0000 or +00:00\n        # convert +0000 -> +00:00\n        if len(s) >= 5 and (s[-5] == '+' or s[-5] == '-') and s[-4:].isdigit():\n            # format like +0000\n            tz = s[-5:]\n            s = s[:-5] + tz[:3] + ':' + tz[3:]\n        elif len(s) >= 6 and (s[-6] == '+' or s[-6] == '-') and s[-5] == '0' and s[-4] == '0':\n            # already +00:00\n            pass\n    # Remove milliseconds if present with dot and more\n    # datetime.fromisoformat can handle microseconds\n    try:\n        return datetime.fromisoformat(s)\n    except Exception:\n        # try removing last colon in timezone if weird\n        s2 = s\n        # fallback: strip timezone and parse naive\n        if '+' in s2:\n            s2 = s2.split('+')[0]\n        if '-' in s2[10:]:\n            # there may be another - for timezone\n            s2 = s2.split('-')[0]\n        try:\n            return datetime.fromisoformat(s2)\n        except Exception:\n            return None\n\n# aggregate durations per state in seconds\nfrom collections import defaultdict\nstate_durations = defaultdict(list)\n\nfor c in cases:\n    acct = c.get('accountid')\n    if acct is None:\n        continue\n    acct_clean = acct.strip()\n    if acct_clean.startswith('#'):\n        acct_clean = acct_clean[1:]\n    acct_clean = acct_clean.strip()\n    state = acct_map.get(acct_clean)\n    if not state:\n        # try also matching raw acct without stripping # if mapping uses it\n        state = acct_map.get(acct_clean)\n    if not state:\n        continue\n    cd = parse_ts(c.get('createddate'))\n    cl = parse_ts(c.get('closeddate'))\n    if cd is None or cl is None:\n        continue\n    # compute duration in hours\n    delta = (cl - cd).total_seconds()\n    if delta < 0:\n        # skip negative durations\n        continue\n    state_durations[state].append(delta)\n\n# compute mean duration per state\nimport statistics\nstate_mean = {}\nfor s, durations in state_durations.items():\n    if len(durations) == 0:\n        continue\n    state_mean[s] = sum(durations) / len(durations)\n\nif not state_mean:\n    result = None\nelse:\n    # pick state with minimum mean duration; if tie, pick state with more cases, then lexicographically\n    min_mean = min(state_mean.values())\n    candidates = [s for s, m in state_mean.items() if abs(m - min_mean) < 1e-6]\n    if len(candidates) == 1:\n        best = candidates[0]\n    else:\n        # pick with max count\n        best = max(candidates, key=lambda s: (len(state_durations.get(s, [])), -ord(s[0])))\n    result = best\n\nprint(\"__RESULT__:\")\nprint(json.dumps(result))", "env": {"var_call_C6wJhhDvYo3I76ED6lavNLyc": [{"id": "500Wt00000DDPIsIAP", "accountid": "#001Wt00000PGRnYIAX", "createddate": "2022-08-05T14:30:00.000+0000", "closeddate": "2022-08-05T14:39:32.000+0000", "status": "Closed "}, {"id": "#500Wt00000DDTERIA5", "accountid": "001Wt00000PGzSaIAL", "createddate": "2022-03-10T09:30:00.000+0000", "closeddate": "2022-03-13T09:45:27.000+0000", "status": "Closed"}, {"id": "#500Wt00000DDYdwIAH", "accountid": "001Wt00000PFj4zIAD", "createddate": "2022-02-03T14:30:00.000+0000", "closeddate": "2022-02-03T14:46:56.000+0000", "status": "Closed"}, {"id": "#500Wt00000DDYpHIAX", "accountid": "#001Wt00000PHHXXIA5", "createddate": "2022-09-05T11:15:00.000+0000", "closeddate": "2022-09-05T11:42:09.000+0000", "status": "Closed"}, {"id": "#500Wt00000DDet1IAD", "accountid": "001Wt00000PGzSbIAL", "createddate": "2021-09-07T23:48:00.000+0000", "close