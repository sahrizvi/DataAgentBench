swith('#'):\n        s = s[1:]\n    return s\n\n# Clean IDs\nif not cases.empty:\n    cases['clean_accountid'] = cases['accountid'].apply(clean_id)\n    cases['createddate'] = pd.to_datetime(cases['createddate'], errors='coerce')\n    cases['closeddate'] = pd.to_datetime(cases['closeddate'], errors='coerce')\n    # compute closure time in hours\n    cases['closure_hours'] = (cases['closeddate'] - cases['createddate']).dt.total_seconds() / 3600.0\nelse:\n    cases['clean_accountid'] = []\n\nif not accounts.empty:\n    accounts['clean_Id'] = accounts['Id'].apply(clean_id)\nelse:\n    accounts['clean_Id'] = []\n\n# Merge\nmerged = pd.merge(cases, accounts, left_on='clean_accountid', right_on='clean_Id', how='left')\n\n# Keep records with valid state and closure_hours\nmerged = merged[merged['closure_hours'].notna() & merged['ShippingState'].notna()]\n\n# Normalize ShippingState by stripping whitespace\nmerged['ShippingState'] = merged['ShippingState'].astype(str).str.strip()\n\n# Group by state\ngroup = merged.groupby('ShippingState').agg(mean_hours=('closure_hours', 'mean'), count=('closure_hours','count')).reset_index()\n\n# If no data, return None\nif group.empty:\n    result = None\nelse:\n    # Find minimum mean_hours, tie-breaker: higher count, then alphabetical\n    min_hours = group['mean_hours'].min()\n    candidates = group[group['mean_hours'] == min_hours]\n    if len(candidates) > 1:\n        candidates = candidates.sort_values(by=['count', 'ShippingState'], ascending=[False, True])\n    best_state = candidates.iloc[0]['ShippingState']\n    result = best_state\n\nprint(\"__RESULT__:\")\nprint(json.dumps(result))", "env": {"var_call_SucywB3RYN9a9M7A1AOvIhYI": [{"id": "500Wt00000DDPIsIAP", "accountid": "#001Wt00000PGRnYIAX", "createddate": "2022-08-05T14:30:00.000+0000", "closeddate": "2022-08-05T14:39:32.000+0000"}, {"id": "#500Wt00000DDTERIA5", "accountid": "001Wt00000PGzSaIAL", "createddate": "2022-03-10T09:30:00.000+0000", "closeddate": "2022-03-13T09:45: