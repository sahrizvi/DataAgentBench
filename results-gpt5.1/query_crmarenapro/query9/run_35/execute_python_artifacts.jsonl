{"val_args": {"code": "import json, pandas as pd\nfrom datetime import datetime\n\n# Load full cases result\npath = var_call_1uXOv0dZYvmQmw3vVFnRo1Ok\nwith open(path, 'r') as f:\n    cases = json.load(f)\n\naccounts = var_call_2svKceC6yKmiAp1o0du55f4x\n\ncases_df = pd.DataFrame(cases)\nacct_df = pd.DataFrame(accounts)\n\n# Clean IDs (remove leading '#')\nfor col in ['id','accountid']:\n    if col in cases_df.columns:\n        cases_df[col] = cases_df[col].astype(str).str.lstrip('#')\nacct_df['Id'] = acct_df['Id'].astype(str).str.lstrip('#')\n\n# Parse datetimes\nfor col in ['createddate','closeddate']:\n    cases_df[col] = pd.to_datetime(cases_df[col], utc=True, errors='coerce')\n\n# Filter to past 6 quarters from today (2022-10-26)\nref = pd.Timestamp('2022-10-26', tz='UTC')\nstart = ref - pd.DateOffset(months=18)\nmask = (cases_df['createddate'] >= start) & (cases_df['createddate'] <= ref)\ncases_df = cases_df[mask].copy()\n\n# Compute resolution time in days\ncases_df['res_days'] = (cases_df['closeddate'] - cases_df['createddate']).dt.total_seconds() / 86400.0\n\n# Join to accounts to get state\nmerged = cases_df.merge(acct_df[['Id','ShippingState']], left_on='accountid', right_on='Id', how='left')\nmerged = merged.dropna(subset=['ShippingState'])\n\n# Define quarters relative to ref\n# Quarter numbering: 0 = most recent quarter (Q4 2022 partial), etc.\nmerged['quarter'] = ((ref.year - merged['createddate'].dt.year) * 4 + (ref.quarter - merged['createddate'].dt.quarter)).astype(int)\n\n# Keep past 6 quarters: 0-5\nmerged = merged[(merged['quarter'] >= 0) & (merged['quarter'] < 6)]\n\n# Compute average by state over this window\nagg = merged.groupby('ShippingState')['res_days'].mean().reset_index()\nagg = agg[agg['res_days'].notna()]\n\n# Get state with minimum avg\nif agg.empty:\n    result = None\nelse:\n    best_state = agg.sort_values('res_days').iloc[0]['ShippingState']\n    result = best_state\n\nout = json.dumps(result)\nprint('__RESULT__:')\nprint(out)", "