{"val_args": {"code": "import json, math, pandas as pd\n\n# Load full RNA expression data from file\nwith open(var_call_JeL0ytJpqNUrxMkiFzVv1wD8, 'r') as f:\n    rna_records = json.load(f)\n\n# Load full clinical data from file\nwith open(var_call_NQ549d2T4GypYSPNz3ZHqveF, 'r') as f:\n    clin_records = json.load(f)\n\nrna_df = pd.DataFrame(rna_records)\nclin_df = pd.DataFrame(clin_records)\n\n# Extract patient barcode from Patient_description texts (TCGA-XX-XXXX)\nimport re\nclin_df['ParticipantBarcode'] = clin_df['Patient_description'].str.extract(r'(TCGA-..-....)')\n\n# Filter out histology annotations enclosed entirely in square brackets\n# Keep rows where histological_type does NOT match \"^[.*]$\" pattern\nmask_valid_hist = ~clin_df['histological_type'].astype(str).str.match(r\"^\\[.*\\]$\")\nclin_df = clin_df[mask_valid_hist]\n\n# Merge on ParticipantBarcode\nmerged = pd.merge(rna_df, clin_df[['ParticipantBarcode','histological_type']], on='ParticipantBarcode', how='inner')\n\n# Convert normalized_count to float and drop invalid\nmerged['normalized_count'] = pd.to_numeric(merged['normalized_count'], errors='coerce')\nmerged = merged.dropna(subset=['normalized_count'])\n\n# Compute log10(normalized_count + 1)\nmerged['log10_expr'] = (merged['normalized_count'] + 1).map(lambda x: math.log10(x))\n\n# Group by histology type and compute mean\nresult = merged.groupby('histological_type')['log10_expr'].mean().sort_index()\n\n# Round to at least 4 decimal places\nresult_rounded = result.round(4)\n\nout = result_rounded.to_dict()\n\nprint(\"__RESULT__:\")\nprint(json.dumps(out))", "env": {"var_call_JeL0ytJpqNUrxMkiFzVv1wD8": "file_storage/call_JeL0ytJpqNUrxMkiFzVv1wD8.json", "var_call_EVHKnIYUDc3BeQfmWBFvUpH0": ["clinical_info"], "var_call_XMWHpszkyynjOXytoVI1Xq3F": [{"column_name": "stopped_smoking_year"}, {"column_name": "days_to_initial_pathologic_diagnosis"}, {"column_name": "number_of_lymphnodes_positive_by_he"}, {"column_name": "age_at_initial_pathologic_diagno