{"val_args": {"code": "import json, re, pandas as pd\n\n# Load full clinical data from file\nwith open(var_call_ykY2oiSVGAeRBj2yOSPdRGd9, 'r') as f:\n    clinical = json.load(f)\n\nclinical_df = pd.DataFrame(clinical)\n\n# Extract patient barcode and vital status from Patient_description\npat = re.compile(r\"patient (TCGA-[A-Z0-9-]+).*?vital status:? ([A-Za-z]+)\", re.IGNORECASE)\nbarcodes = []\nvital_statuses = []\nfor desc in clinical_df['Patient_description']:\n    m = pat.search(desc)\n    if m:\n        barcodes.append(m.group(1))\n        vital_statuses.append(m.group(2).capitalize())\n    else:\n        barcodes.append(None)\n        vital_statuses.append(None)\n\nclinical_df['ParticipantBarcode'] = barcodes\nclinical_df['vital_status'] = vital_statuses\n\n# Filter to BRCA using diagnosis string containing 'Breast' (PanCancer hint typo about BRCA)\nbrca_mask = clinical_df['Patient_description'].str.contains('Breast', case=False, na=False)\nbrca_df = clinical_df[brca_mask].copy()\n\n# Alive patients\nalive_brca = brca_df[brca_df['vital_status'] == 'Alive'].copy()\n\n# Load CDH1 mutation participants\nwith open(var_call_uIc7SXLL9JiIVUF27WIYMzIf, 'r') as f:\n    mut = json.load(f)\nmut_df = pd.DataFrame(mut)\nmut_pats = set(mut_df['ParticipantBarcode'].unique())\n\nalive_brca['has_CDH1_mut'] = alive_brca['ParticipantBarcode'].isin(mut_pats)\n\n# For each histological_type compute percentage mutated among alive BRCA\nsummary = alive_brca.groupby('histological_type').agg(\n    n_patients=('ParticipantBarcode','nunique'),\n    n_mut=('has_CDH1_mut', lambda x: int(x.sum()))\n).reset_index()\nsummary['pct_mutated'] = (summary['n_mut'] / summary['n_patients'] * 100).round(2)\n\nsummary = summary[summary['n_patients'] > 0]\nsummary_sorted = summary.sort_values('pct_mutated', ascending=False).head(3)\n\nresult = summary_sorted.to_dict(orient='records')\n\nout = json.dumps(result)\nprint('__RESULT__:')\nprint(out)", "env": {"var_call_uIc7SXLL9JiIVUF27WIYMzIf": "file_stor