{"val_args": {"code": "import re, json, pandas as pd\nfrom collections import Counter\n\n# Load full clinical BRCA file\nimport pathlib, os, ast\npath = var_call_pugjlWG6vgf1tqhkcFuiPHiZ\nwith open(path, 'r') as f:\n    clinical = json.load(f)\n\n# Keep only alive patients and extract barcode and histology\nalive_records = []\nfor row in clinical:\n    desc = row.get('Patient_description','')\n    m = re.search(r'patient (TCGA-[A-Z0-9\\-]+)', desc)\n    if not m:\n        m = re.search(r'barcode (TCGA-[A-Z0-9\\-]+)', desc)\n    if not m:\n        continue\n    barcode = m.group(1)\n    if 'vital status is Alive' in desc or 'vital status: Alive' in desc or 'vital status = Alive' in desc:\n        alive_records.append({'ParticipantBarcode': barcode, 'histological_type': row.get('histological_type')})\n\nclinical_df = pd.DataFrame(alive_records).dropna(subset=['histological_type'])\n\n# Load CDH1 mutation participants\npath2 = var_call_bgU3fput97gqS3YibFQAzJ6d\nwith open(path2, 'r') as f:\n    muts = json.load(f)\n\nmuts_df = pd.DataFrame(muts).drop_duplicates(subset=['ParticipantBarcode'])\n\n# Merge to get BRCA alive patients and whether mutated\nmerged = clinical_df.merge(muts_df[['ParticipantBarcode']], on='ParticipantBarcode', how='left', indicator=True)\nmerged['CDH1_mutated'] = merged['_merge'] == 'both'\n\n# For each histological_type compute mutation percentage\nsummary = merged.groupby('histological_type')['CDH1_mutated'].agg(['mean','count','sum']).reset_index()\nsummary = summary[summary['count']>=1]\nsummary['mutation_percentage'] = (summary['mean']*100).round(2)\nsummary = summary.sort_values('mutation_percentage', ascending=False).head(3)\n\nresult = summary[['histological_type','mutation_percentage','count','sum']].to_dict(orient='records')\n\nprint(\"__RESULT__:\")\nprint(json.dumps(result))", "env": {"var_call_bgU3fput97gqS3YibFQAzJ6d": "file_storage/call_bgU3fput97gqS3YibFQAzJ6d.json", "var_call_kVNDdcMpkIkWFwLAz4hGJSVv": ["clinical_info"], "var_call