{"val_args": {"code": "import json, pandas as pd, re\n\n# Load full Mongo result if it's a file path\nbiz_raw = var_call_wYVGfcgXPOGGr3ZIGUEYXWF4\nif isinstance(biz_raw, str):\n    import pathlib\n    p = pathlib.Path(biz_raw)\n    if p.is_file():\n        biz_raw = json.load(open(p, 'r'))\n\nbiz_df = pd.DataFrame(biz_raw)\n\n# Extract state from description using pattern 'City, ST,' or 'City, ST ' where ST is two uppercase letters\nstate_pattern = re.compile(r\",\\s*([A-Z]{2})[\\s,]\")\n\ndef extract_state(desc):\n    if not isinstance(desc, str):\n        return None\n    m = state_pattern.search(desc)\n    if m:\n        return m.group(1)\n    return None\n\nbiz_df['state'] = biz_df['description'].apply(extract_state)\n\n# Filter to US states only (ignore non-US like AB)\nus_states = set(['AL','AK','AZ','AR','CA','CO','CT','DE','FL','GA','HI','ID','IL','IN','IA','KS','KY','LA','ME','MD','MA','MI','MN','MS','MO','MT','NE','NV','NH','NJ','NM','NY','NC','ND','OH','OK','OR','PA','RI','SC','SD','TN','TX','UT','VT','VA','WA','WV','WI','WY','DC'])\n\nbiz_df = biz_df[biz_df['state'].isin(us_states)]\n\n# Keep only WiFi-offering businesses: assume attributes.WiFi field indicates 'free' or 'paid' vs 'no'\n# Normalize WiFi string\n\ndef wifi_offered(val):\n    if not isinstance(val, (str, bytes)):\n        return False\n    s = str(val).lower()\n    return 'free' in s or 'paid' in s or 'yes' in s\n\nwifi_vals = biz_df['attributes'].apply(lambda d: d.get('WiFi') if isinstance(d, dict) else None)\n\nbiz_df = biz_df[wifi_vals.apply(wifi_offered)]\n\n# Map business_id -> state\nbiz_state = biz_df[['business_id','state']].copy()\n\n# Prepare review averages\nrev_df = pd.DataFrame(var_call_otItES0UzKq85VTXPLUMOfeB)\nrev_df['business_id'] = rev_df['business_ref'].str.replace('businessref_','businessid_', regex=False)\nrev_df['avg_rating'] = rev_df['avg_rating'].astype(float)\n\n# Join to get only WiFi businesses with reviews\nmerged = rev_df.merge(biz_state, on='business_id', how='inner')\n\n# Count businesses per state and average rating across those businesses\nstate_group = merged.groupby('state').agg(num_businesses=('business_id','nunique'), avg_rating=('avg_rating','mean')).reset_index()\n\nif state_group.empty:\n    result = {\"state\": None, \"num_businesses\": 0, \"avg_rating\": None}\nelse:\n    top = state_group.sort_values(['num_businesses','avg_rating'], ascending=[False,False]).iloc[0]\n    result = {\"state\": top['state'], \"num_businesses\": int(top['num_businesses']), \"avg_rating\": round(float(top['avg_rating']),3)}\n\nout = json.dumps(result)\nprint(\"__RESULT__:\")\nprint(out)", "env": {"var_call_wYVGfcgXPOGGr3ZIGUEYXWF4": "file_storage/call_wYVGfcgXPOGGr3ZIGUEYXWF4.json", "var_call_otItES0UzKq85VTXPLUMOfeB": [{"business_ref": "businessref_79", "avg_rating": "4.627906976744186"}, {"business_ref": "businessref_44", "avg_rating": "2.9285714285714284"}, {"business_ref": "businessref_13", "avg_rating": "3.9166666666666665"}, {"business_ref": "businessref_87", "avg_rating": "3.3333333333333335"}, {"business_ref": "businessref_66", "avg_rating": "2.1818181818181817"}, {"business_ref": "businessref_9", "avg_rating": "4.435897435897436"}, {"business_ref": "businessref_25", "avg_rating": "4.444444444444445"}, {"business_ref": "businessref_2", "avg_rating": "4.769230769230769"}, {"business_ref": "businessref_74", "avg_rating": "2.8333333333333335"}, {"business_ref": "businessref_59", "avg_rating": "4.6"}, {"business_ref": "businessref_5", "avg_rating": "1.6"}, {"business_ref": "businessref_29", "avg_rating": "3.9047619047619047"}, {"business_ref": "businessref_58", "avg_rating": "4.166666666666667"}, {"business_ref": "businessref_39", "avg_rating": "4.125"}, {"business_ref": "businessref_100", "avg_rating": "4.0"}, {"business_ref": "businessref_81", "avg_rating": "3.6666666666666665"}, {"business_ref": "businessref_93", "avg_rating": "2.857142857142857"}, {"business_ref": "businessref_67", "avg_rating": "3.3260869565217392"}, {"bu