{"val_args": {"code": "import json, pandas as pd, re, os\n\n# Load full Mongo result if it's a file path\nbiz_data = var_call_LGpJL56I3tAqE8BfYcu7iq4F\nif isinstance(biz_data, str) and os.path.isfile(biz_data):\n    with open(biz_data, 'r') as f:\n        biz_data = json.load(f)\n\nreviews = var_call_03PGWBI4sCvT6FS1cRSq5XAd\n\nbiz_df = pd.DataFrame(biz_data)\nrev_df = pd.DataFrame(reviews)\n\n# Extract US state abbreviation from description (pattern: \", XX,\" where XX are 2 capital letters)\nstate_pattern = re.compile(r',\\s*([A-Z]{2}),')\n\ndef extract_state(desc):\n    if not isinstance(desc, str):\n        return None\n    m = state_pattern.search(desc)\n    if not m:\n        return None\n    return m.group(1)\n\nbiz_df['state'] = biz_df['description'].apply(extract_state)\n\n# Keep only US states (two-letter codes, but exclude non-US like AB)\nnon_us = {'AB', 'BC', 'ON', 'QC', 'MB', 'SK', 'NS', 'NB', 'NL', 'PE', 'YT', 'NT', 'NU'}\nmask_us = biz_df['state'].notna() & ~biz_df['state'].isin(non_us)\nusa_biz = biz_df[mask_us].copy()\n\n# Map business_id to business_ref\nusa_biz['business_ref'] = usa_biz['business_id'].str.replace('businessid_', 'businessref_', regex=False)\n\n# Join with review averages\nmerged = usa_biz.merge(rev_df, how='left', left_on='business_ref', right_on='business_ref')\n\n# Count businesses with WiFi per state and average rating over those businesses (using avg_rating from reviews)\n\n# First, convert avg_rating to float\nmerged['avg_rating'] = pd.to_numeric(merged['avg_rating'], errors='coerce')\n\nstate_stats = merged.groupby('state').agg(\n    wifi_business_count=('business_id', 'nunique'),\n    state_avg_rating=('avg_rating', 'mean')\n).reset_index()\n\n# Find state with max Wifi businesses\nstate_stats = state_stats.dropna(subset=['wifi_business_count'])\nstate_stats = state_stats[state_stats['wifi_business_count'] > 0]\n\nif state_stats.empty:\n    result = {\"state\": None, \"wifi_businesses\": 0, \"avg_rating\": None}\nelse:\n    top = state_stats.sort_values(['wifi_business_count', 'state_avg_rating'], ascending=[False, False]).iloc[0]\n    result = {\n        \"state\": top['state'],\n        \"wifi_businesses\": int(top['wifi_business_count']),\n        \"avg_rating\": None if pd.isna(top['state_avg_rating']) else round(float(top['state_avg_rating']), 3)\n    }\n\nout = json.dumps(result)\nprint(\"__RESULT__:\")\nprint(out)", "env": {"var_call_LGpJL56I3tAqE8BfYcu7iq4F": "file_storage/call_LGpJL56I3tAqE8BfYcu7iq4F.json", "var_call_03PGWBI4sCvT6FS1cRSq5XAd": [{"business_ref": "businessref_79", "avg_rating": "4.627906976744186"}, {"business_ref": "businessref_44", "avg_rating": "2.9285714285714284"}, {"business_ref": "businessref_13", "avg_rating": "3.9166666666666665"}, {"business_ref": "businessref_87", "avg_rating": "3.3333333333333335"}, {"business_ref": "businessref_47", "avg_rating": "3.9047619047619047"}, {"business_ref": "businessref_16", "avg_rating": "3.024390243902439"}, {"business_ref": "businessref_46", "avg_rating": "4.181818181818182"}, {"business_ref": "businessref_91", "avg_rating": "4.911111111111111"}, {"business_ref": "businessref_1", "avg_rating": "4.333333333333333"}, {"business_ref": "businessref_55", "avg_rating": "4.918918918918919"}, {"business_ref": "businessref_73", "avg_rating": "5.0"}, {"business_ref": "businessref_6", "avg_rating": "4.0"}, {"business_ref": "businessref_71", "avg_rating": "3.268292682926829"}, {"business_ref": "businessref_38", "avg_rating": "3.1176470588235294"}, {"business_ref": "businessref_32", "avg_rating": "3.4285714285714284"}, {"business_ref": "businessref_30", "avg_rating": "3.6"}, {"business_ref": "businessref_59", "avg_rating": "4.6"}, {"business_ref": "businessref_5", "avg_rating": "1.6"}, {"business_ref": "businessref_29", "avg_rating": "3.9047619047619047"}, {"business_ref": "businessref_58", "avg_rating": "4.166666666666667"}, {"business_ref": "businessref_39", "avg_rating": "4.125"}, {"business_ref": "businessref_100", "avg_rati