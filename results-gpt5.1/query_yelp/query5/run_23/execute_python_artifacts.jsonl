{"val_args": {"code": "import re, json, pandas as pd\n\n# Load business wifi data from file path\npath = var_call_mka36UtvbX5Xu6hhWEbI8kjC\nwith open(path, 'r') as f:\n    wifi_records = json.load(f)\n\n# Filter to businesses that actually offer wifi (value contains 'free' or 'paid', case-insensitive)\nrows = []\nfor rec in wifi_records:\n    wifi_val = None\n    attrs = rec.get('attributes') or {}\n    if isinstance(attrs, dict):\n        wifi_val = attrs.get('WiFi')\n    if not isinstance(wifi_val, str):\n        continue\n    if 'free' not in wifi_val.lower() and 'paid' not in wifi_val.lower():\n        continue\n    desc = rec.get('description') or ''\n    m = re.search(r', ([A-Z]{2}) \\d{5}', desc)\n    if not m:\n        continue\n    state = m.group(1)\n    rows.append({'business_id': rec.get('business_id'), 'state': state})\n\nbiz_df = pd.DataFrame(rows)\n\n# Count businesses with wifi per state\nstate_counts = biz_df.groupby('state').agg(count=('business_id','nunique')).reset_index()\n\n# Determine state with highest count\nif state_counts.empty:\n    result = {'state': None, 'average_rating': None}\nelse:\n    top_state_row = state_counts.sort_values(['count','state'], ascending=[False, True]).iloc[0]\n    top_state = top_state_row['state']\n    # businesses in that state\n    top_biz = biz_df[biz_df['state'] == top_state].copy()\n    # Map to business_ref\n    top_biz['business_ref'] = top_biz['business_id'].str.replace('businessid_','businessref_', regex=False)\n    review_avgs = pd.DataFrame(var_call_zH2hlhmIPYMlAwgZ4afJqa8p)\n    merged = pd.merge(top_biz, review_avgs, on='business_ref', how='left')\n    merged['avg_rating'] = pd.to_numeric(merged['avg_rating'], errors='coerce')\n    overall_avg = merged['avg_rating'].mean()\n    if pd.isna(overall_avg):\n        avg_val = None\n    else:\n        avg_val = round(float(overall_avg), 3)\n    result = {'state': top_state, 'average_rating': avg_val}\n\nout = json.dumps(result)\nprint(\"__RESULT__:\")\npri