{"val_args": {"code": "import json, re, pandas as pd\n\npath_info = var_call_esBkqb4T5TiuSkkLdl3FbR53\nif isinstance(path_info, str) and path_info.endswith('.json'):\n    with open(path_info, 'r') as f:\n        business_wifi = json.load(f)\nelse:\n    business_wifi = path_info\n\nreviews_avg = var_call_7XHhXoHqnMTeVpaTTsxSuuZ4\n\nstate_pattern = re.compile(r',\\s*([A-Z]{2})\\b')\n\nrecords = []\nfor b in business_wifi:\n    desc = b.get('description') or ''\n    m = None\n    for match in state_pattern.finditer(desc):\n        m = match\n    if not m:\n        continue\n    state = m.group(1)\n    attrs = b.get('attributes') or {}\n    wifi_val = None\n    if isinstance(attrs, dict) and 'WiFi' in attrs:\n        wifi_val = attrs['WiFi']\n    records.append({\n        'business_id': b.get('business_id'),\n        'state': state,\n        'wifi_val': wifi_val\n    })\n\nbiz_df = pd.DataFrame(records)\n\nif 'wifi_val' not in biz_df.columns or biz_df.empty:\n    result = {}\nelse:\n    mask = biz_df['wifi_val'].astype(str).str.contains('free', case=False) | biz_df['wifi_val'].astype(str).str.contains('paid', case=False)\n    wifi_biz_df = biz_df[mask].copy()\n\n    wifi_biz_df['business_ref'] = wifi_biz_df['business_id'].str.replace('businessid_', 'businessref_', regex=False)\n\n    rev_df = pd.DataFrame(reviews_avg)\n    merged = pd.merge(wifi_biz_df, rev_df, how='left', on='business_ref')\n\n    merged['avg_rating'] = pd.to_numeric(merged['avg_rating'], errors='coerce')\n\n    state_group = merged.groupby('state').agg(\n        wifi_business_count=('business_id', 'nunique'),\n        avg_rating_state=('avg_rating', 'mean')\n    ).reset_index()\n\n    state_group = state_group.sort_values(['wifi_business_count', 'state'], ascending=[False, True])\n\n    top = state_group.iloc[0].to_dict() if not state_group.empty else {}\n\n    import math\n    if top and isinstance(top.get('avg_rating_state'), float) and not math.isnan(top['avg_rating_state']):\n        top['avg_rating_state'] = round(top['avg_rating_state'], 3)\n\n    result = top\n\nprint(\"__RESULT__:\")\nprint(json.dumps(result))", "env": {"var_call_esBkqb4T5TiuSkkLdl3FbR53": "file_storage/call_esBkqb4T5TiuSkkLdl3FbR53.json", "var_call_SZXDFxUmGx7Yco7qEVTrPuDx": ["review", "tip", "user"], "var_call_7XHhXoHqnMTeVpaTTsxSuuZ4": [{"business_ref": "businessref_47", "avg_rating": "3.9047619047619047"}, {"business_ref": "businessref_16", "avg_rating": "3.024390243902439"}, {"business_ref": "businessref_46", "avg_rating": "4.181818181818182"}, {"business_ref": "businessref_91", "avg_rating": "4.911111111111111"}, {"business_ref": "businessref_1", "avg_rating": "4.333333333333333"}, {"business_ref": "businessref_55", "avg_rating": "4.918918918918919"}, {"business_ref": "businessref_73", "avg_rating": "5.0"}, {"business_ref": "businessref_6", "avg_rating": "4.0"}, {"business_ref": "businessref_71", "avg_rating": "3.268292682926829"}, {"business_ref": "businessref_38", "avg_rating": "3.1176470588235294"}, {"business_ref": "businessref_32", "avg_rating": "3.4285714285714284"}, {"business_ref": "businessref_30", "avg_rating": "3.6"}, {"business_ref": "businessref_79", "avg_rating": "4.627906976744186"}, {"business_ref": "businessref_44", "avg_rating": "2.9285714285714284"}, {"business_ref": "businessref_13", "avg_rating": "3.9166666666666665"}, {"business_ref": "businessref_87", "avg_rating": "3.3333333333333335"}, {"business_ref": "businessref_66", "avg_rating": "2.1818181818181817"}, {"business_ref": "businessref_9", "avg_rating": "4.435897435897436"}, {"business_ref": "businessref_25", "avg_rating": "4.444444444444445"}, {"business_ref": "businessref_2", "avg_rating": "4.769230769230769"}, {"business_ref": "businessref_74", "avg_rating": "2.8333333333333335"}, {"business_ref": "businessref_59", "avg_rating": "4.6"}, {"business_ref": "businessref_5", "avg_rating": "1.6"}, {"business_ref": "businessref_29", "avg_rating": "3.9047619047619047"}, {"business_ref": "businessref_58", "avg_ra