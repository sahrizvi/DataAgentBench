{"val_args": {"code": "import json, pandas as pd, re, os\n\n# Load full business wifi result from file\npath = var_call_FbvHua4O87yKzptQ4mdSiAKF\nwith open(path, 'r') as f:\n    business_wifi = json.load(f)\n\nbiz_df = pd.DataFrame(business_wifi)\n\n# Extract state from description like \", FL,\" or \", California,\" using regex (2-letter state first)\nstate_pattern = re.compile(r\",\\s*([A-Z]{2})\\s*,\")\n\nstates = []\nfor desc in biz_df.get('description', '').fillna(''):\n    m = state_pattern.search(desc)\n    states.append(m.group(1) if m else None)\n\nbiz_df['state'] = states\n\n# Filter to US states (2-letter codes) and WiFi not 'no'\nwifi_vals = biz_df['attributes'].apply(lambda x: x.get('WiFi') if isinstance(x, dict) else None)\n\nbiz_df['wifi_value'] = wifi_vals.astype(str).str.lower()\n\nwifi_yes = biz_df[biz_df['wifi_value'].str.contains('free')]\n\n# Count by state\nstate_counts = wifi_yes.groupby('state').size().reset_index(name='count')\nstate_counts = state_counts.dropna().sort_values('count', ascending=False)\n\nif state_counts.empty:\n    result = {\"state\": None, \"avg_rating\": None}\nelse:\n    top_state = state_counts.iloc[0]['state']\n    wifi_yes['business_ref'] = wifi_yes['business_id'].str.replace('businessid_', 'businessref_', regex=False)\n\n    reviews = pd.DataFrame(var_call_jGKCiyMTW5yKWpqGyQRmJ62y)\n    merged = wifi_yes.merge(reviews, left_on='business_ref', right_on='business_ref', how='left')\n    merged_state = merged[merged['state'] == top_state]\n    merged_state['avg_rating'] = pd.to_numeric(merged_state['avg_rating'], errors='coerce')\n    avg_rating_state = merged_state['avg_rating'].mean()\n    if pd.isna(avg_rating_state):\n        avg_rating_state = None\n    else:\n        avg_rating_state = round(float(avg_rating_state), 2)\n    result = {\"state\": top_state, \"avg_rating\": avg_rating_state}\n\nout = json.dumps(result)\nprint(\"__RESULT__:\")\nprint(out)", "env": {"var_call_FbvHua4O87yKzptQ4mdSiAKF": "file_storage/cal