{"val_args": {"code": "import json, re, pandas as pd\n\npath = var_call_cQSLf5mN0vPBSX8pBKqVQAdL\nwith open(path, 'r') as f:\n    business_records = json.load(f)\n\nbiz_df = pd.DataFrame(business_records)\nrev_df = pd.DataFrame(var_call_m3bmcM8cjY8eCXJV4PAy1dKT)\n\nstate_pattern = re.compile(r',\\s*([A-Z]{2})\\b')\n\ndef extract_state(desc):\n    if not isinstance(desc, str):\n        return None\n    m = state_pattern.search(desc)\n    if m:\n        return m.group(1)\n    return None\n\n# Ensure we don't overwrite existing 'state' column\nif 'state' not in biz_df.columns:\n    biz_df['state'] = biz_df['description'].apply(extract_state)\nelse:\n    biz_df['state_extracted'] = biz_df['description'].apply(extract_state)\n    biz_df['state'] = biz_df['state'].fillna(biz_df['state_extracted'])\n\nrev_df['business_id'] = rev_df['business_ref'].str.replace('businessref_', 'businessid_', regex=False)\n\nmerged = pd.merge(rev_df, biz_df[['business_id', 'state']], on='business_id', how='left')\nmerged = merged.dropna(subset=['state'])\n\nmerged['review_count'] = merged['review_count'].astype(float)\nmerged['avg_rating'] = merged['avg_rating'].astype(float)\n\nstate_stats = merged.groupby('state').apply(\n    lambda g: pd.Series({\n        'total_reviews': g['review_count'].sum(),\n        'weighted_avg_rating': (g['avg_rating'] * g['review_count']).sum() / g['review_count'].sum()\n    })\n).reset_index()\n\n# In case of ties, just take the first after sorting by state as secondary key\nstate_stats = state_stats.sort_values(['total_reviews', 'state'], ascending=[False, True])\n top = state_stats.iloc[0]\n\nresult = {\n    'state_with_most_reviews': top['state'],\n    'total_reviews_in_state': float(top['total_reviews']),\n    'average_rating_in_state_weighted_by_reviews': float(round(top['weighted_avg_rating'], 3))\n}\n\nout = json.dumps(result)\nprint(\"__RESULT__:\")\nprint(out)", "env": {"var_call_cQSLf5mN0vPBSX8pBKqVQAdL": "file_storage/call_cQSLf5mN0vPBSX8pBKqVQAdL.jso