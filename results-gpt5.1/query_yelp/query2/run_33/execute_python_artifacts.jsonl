{"val_args": {"code": "import json, re, pandas as pd\n\n# business info is in a json file path\npath = var_call_Tjm0p8WRc8ONQhemt6WaB1eG\nwith open(path, 'r') as f:\n    biz_records = json.load(f)\n\nbiz_df = pd.DataFrame(biz_records)\n\n# extract state abbreviation from description, assume pattern \", XX\" where XX is 2 capital letters\nstate_pattern = re.compile(r',\\s*([A-Z]{2})\\b')\n\ndef extract_state(desc):\n    if not isinstance(desc, str):\n        return None\n    m = state_pattern.search(desc)\n    return m.group(1) if m else None\n\nbiz_df['state'] = biz_df['description'].apply(extract_state)\n\n# map business_ref -> business_id using numeric suffix\nrev_df = pd.DataFrame(var_call_k9lZ33rSLhYHipYHGaKUJsQ5)\n\ndef ref_to_id(ref):\n    # businessref_123 -> businessid_123\n    if not isinstance(ref, str):\n        return None\n    return ref.replace('businessref_', 'businessid_')\n\nrev_df['business_id'] = rev_df['business_ref'].apply(ref_to_id)\nrev_df['review_cnt'] = rev_df['review_cnt'].astype(int)\nrev_df['avg_rating'] = rev_df['avg_rating'].astype(float)\n\nmerged = pd.merge(rev_df, biz_df[['business_id', 'state']], on='business_id', how='left')\n\n# drop rows without state\nmerged = merged.dropna(subset=['state'])\n\nstate_group = merged.groupby('state').agg(total_reviews=('review_cnt', 'sum'), avg_rating=('avg_rating', 'mean')).reset_index()\n\n# find state with max total_reviews\nif len(state_group) == 0:\n    result = None\nelse:\n    top = state_group.sort_values('total_reviews', ascending=False).iloc[0]\n    result = {\n        'state': top['state'],\n        'total_reviews': int(top['total_reviews']),\n        'average_business_rating_in_state': round(float(top['avg_rating']), 3)\n    }\n\nout = json.dumps(result)\nprint('__RESULT__:')\nprint(out)", "env": {"var_call_Tjm0p8WRc8ONQhemt6WaB1eG": "file_storage/call_Tjm0p8WRc8ONQhemt6WaB1eG.json", "var_call_k9lZ33rSLhYHipYHGaKUJsQ5": [{"business_ref": "businessref_79", "review_cnt": "43", "avg_ratin