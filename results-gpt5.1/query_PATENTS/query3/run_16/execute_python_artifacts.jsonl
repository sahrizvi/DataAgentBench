{"val_args": {"code": "import json, re, pandas as pd\nfrom pathlib import Path\n\nfile_path = var_call_85agtXn4yMJ9doYs8dKBlGQk\nrecords = json.loads(Path(file_path).read_text())\n\nassignee_cpc = {}\nfor r in records:\n    pi = r['Patents_info']\n    m = re.search(r'assignee_harmonized: ([^,]+)', pi)\n    if not m:\n        m = re.search(r'is assigned to ([^,]+)', pi)\n    if not m:\n        m = re.search(r'is belonging to ([^,]+)', pi)\n    if not m:\n        m = re.search(r'is owned by ([^,]+)', pi)\n    if not m:\n        continue\n    assignee = m.group(1).strip()\n    if assignee.upper().startswith('UNIV CALIFORNIA'):\n        continue\n    cpcs = json.loads(r['cpc']) if r['cpc'] else []\n    primary = None\n    for c in cpcs:\n        if c.get('first') and c.get('inventive'):\n            primary = c['code']\n            break\n    if not primary and cpcs:\n        primary = cpcs[0]['code']\n    if not primary:\n        continue\n    assignee_cpc.setdefault(assignee, set()).add(primary)\n\nrows = []\nfor a, codes in assignee_cpc.items():\n    for code in codes:\n        rows.append({'assignee': a, 'cpc_code': code})\n\nresult = json.dumps(rows[:200])\nprint('__RESULT__:')\nprint(result)", "env": {"var_call_qFnaau0NoYSbxay1E6TKk17f": [], "var_call_3jFRaMkxB6kp8jDu92jHndqr": ["cpc_definition"], "var_call_f10qhJHNjSyAxBYplph0Wqsl": "file_storage/call_f10qhJHNjSyAxBYplph0Wqsl.json", "var_call_e4I3uxid1IrfIjjUU2g5kouy": ["CN-101061570-A", "CN-101086963-A", "CN-101631902-A", "CN-102964610-A", "CN-103224947-A", "CN-103233028-A", "CN-103343120-A", "CN-104264260-A", "CN-106880693-A", "CN-107058224-A", "CN-1237247-A", "CN-1346403-A", "CN-1413250-A", "CN-85101623-A", "DE-1509371-A1", "EP-0111214-A2", "EP-0399833-A1", "EP-0474891-A1", "EP-0474894-A1", "EP-0476808-A1", "EP-0497542-A1", "EP-0513982-A2", "EP-0524013-A1", "EP-0640846-B1", "EP-0922957-A1", "EP-1122806-A1", "EP-1699104-A1", "EP-1939202-A1", "EP-2162185-B1", "EP-2341149-A1", "EP-2355893-B1", "EP-2440284-B1", "E