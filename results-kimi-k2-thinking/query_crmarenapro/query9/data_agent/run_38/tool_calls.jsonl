   return id_str.lstrip('#')\n\ncases_df['accountid_clean'] = cases_df['accountid'].apply(clean_id)\naccounts_df['Id_clean'] = accounts_df['Id'].apply(clean_id)\n\n# Clean trailing whitespace\naccounts_df['ShippingState_clean'] = accounts_df['ShippingState'].str.strip()\n\n# Join cases with accounts\ncases_with_state = cases_df.merge(\n    accounts_df[['Id_clean', 'ShippingState_clean']],\n    left_on='accountid_clean',\n    right_on='Id_clean',\n    how='inner'\n)\n\nprint(f\"Number of cases after join: {len(cases_with_state)}\")\nprint(f\"Cases with null state: {cases_with_state['ShippingState_clean'].isnull().sum()}\")\n\n# Convert date strings to datetime\ndef parse_datetime(date_str):\n    if date_str is None:\n        return None\n    try:\n        # Handle the format from Salesforce: 2022-08-05T14:30:00.000+0000\n        return datetime.strptime(date_str.split('.')[0], '%Y-%m-%dT%H:%M:%S')\n    except:\n        return None\n\ncases_with_state['created_dt'] = cases_with_state['createddate'].apply(parse_datetime)\ncases_with_state['closed_dt'] = cases_with_state['closeddate'].apply(parse_datetime)\n\n# Calculate closure time in hours\ncases_with_state['closure_hours'] = (cases_with_state['closed_dt'] - cases_with_state['created_dt']).dt.total_seconds() / 3600\n\n# Filter out invalid closure times (negative or very large outliers)\nvalid_cases = cases_with_state[\n    (cases_with_state['closure_hours'] > 0) & \n    (cases_with_state['closure_hours'] < 8760)  # Max 1 year\n]\n\nprint(f\"Number of valid cases: {len(valid_cases)}\")\n\n# Group by state and calculate metrics\nif len(valid_cases) > 0:\n    state_metrics = valid_cases.groupby('ShippingState_clean').agg({\n        'closure_hours': ['mean', 'median', 'count']\n    }).round(2)\n    \n    state_metrics.columns = ['avg_hours', 'median_hours', 'case_count']\n    state_metrics = state_metrics.reset_index()\n    \n    # Filter states with at least 5 cases for statistical significance\n    significant_states = state_metrics[state_metrics['case_count'] >= 5]\n    \n    print(\"States with 5+ cases:\")\n    print(significant_states.sort_values('avg_hours'))\n    \n    if len(significant_states) > 0:\n        fastest_state = significant_states.loc[significant_states['avg_hours'].idxmin()]\n        result_state = fastest_state['ShippingState_clean']\n        result_avg_hours = fastest_state['avg_hours']\n        result_count = fastest_state['case_count']\n        \n        print(f\"Fastest state: {result_state} with avg {result_avg_hours:.2f} hours ({result_count} cases)\")\n    else:\n        print(\"No states with 5+ cases found\")\n        if len(state_metrics) > 0:\n            fastest_state = state_metrics.loc[state_metrics['avg_hours'].idxmin()]\n            result_state = fastest_state['ShippingState_clean']\n            result_avg_hours = fastest_state['avg_hours']\n            result_count = fastest_state['case_count']\n            print(f\"Fastest state (with {result_count} cases): {result_state} with avg {result_avg_hours:.2f} hours\")\n        else:\n            result_state = None\nelse:\n    result_state = None\n    print(\"No valid cases found\")\n\n# Return the result\nprint('__RESULT__:')\nif result_state:\n    # Ensure it's a two-letter state code\n    result_state_clean = str(result_state).strip()\n    print(json.dumps(result_state_clean))\nelse:\n    print(json.dumps(None))", "env": {"var_functions.query_db:0": [{"id": "500Wt00000DDPIsIAP", "accountid": "#001Wt00000PGRnYIAX", "createddate": "2022-08-05T14:30:00.000+0000", "closeddate": "2022-08-05T14:39:32.000+0000"}, {"id": "#500Wt00000DDTERIA5", "accountid": "001Wt00000PGzSaIAL", "createddate": "2022-03-10T09:30:00.000+0000", "closeddate": "2022-03-13T09:45:27.000+0000"}, {"id": "#500Wt00000DDYdwIAH", "accountid": "001Wt00000PFj4zIAD", "createddate": "2022-02-03T14:30:00.000+0000", "closeddate": "2022-02-03T14:46:56.000+0000"}, {"id": "#500Wt00000DDYpHIAX", "accountid": "#001Wt00000PHHXXIA5", "createdda